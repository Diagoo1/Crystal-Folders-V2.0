<Window x:Class="CrystalFolders.HelpDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource Help}" Height="391" Width="420"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        MouseLeftButtonDown="Window_MouseLeftButtonDown"
        TextOptions.TextRenderingMode="ClearType"
        TextOptions.TextFormattingMode="Display"
        UseLayoutRounding="True" 
        SnapsToDevicePixels="True">

    <!-- الخلفية الآن تتبع CardBackground والحدود تتبع BorderColor -->
    <Border Background="{DynamicResource CardBackground}" CornerRadius="18" BorderBrush="{DynamicResource BorderColor}" BorderThickness="1" Margin="12">
        <Border.Effect>
            <DropShadowEffect BlurRadius="20" ShadowDepth="0" Opacity="0.15" Color="Black"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="55"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- الهيدر يتبع AccentColor المختار -->
            <Border Grid.Row="0" Background="{DynamicResource AccentColor}" CornerRadius="17,17,0,0">
                <Grid Margin="20,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Path Data="M11,18h2v-2h-2V18z M12,2C6.48,2,2,6.48,2,12s4.48,10,10,10s10-4.48,10-10S17.52,2,12,2z M12,20c-4.41,0-8-3.59-8-8 s3.59-8,8-8s8,3.59,8,8S16.41,20,12,20z M12,6c-2.21,0-4,1.79-4,4h2c0-1.1,0.9-2,2-2s2,0.9,2,2c0,2-3,1.75-3,5h2 c0-2.25,3-2.5,3-5C16,7.79,14.21,6,12,6z" 
                              Fill="White" Stretch="Uniform" Width="18" Height="18"/>
                        <TextBlock Text="{DynamicResource HelpDialogTitle}" Foreground="White" FontSize="15" FontWeight="SemiBold" Margin="12,0,0,0" VerticalAlignment="Center"/>
                    </StackPanel>

                    <Button HorizontalAlignment="Right" VerticalAlignment="Center" 
                            Background="Transparent" BorderThickness="0" Cursor="Hand" Click="Close_Click">
                        <Path Data="M19,6.41L17.59,5L12,10.59L6.41,5L5,6.41L10.59,12L5,17.59L6.41,19L12,13.41L17.59,19L19,17.59L13.41,12z" 
                              Fill="#ffffff" Stretch="Uniform" Width="14" Height="14"/>
                    </Button>
                </Grid>
            </Border>

            <Grid Grid.Row="1" Margin="25,20">
                <StackPanel>
                    <!-- خلفية النص تتبع HoverColor المريح للعين في الدارك مود -->
                    <Border Background="{DynamicResource HoverColor}" CornerRadius="10" Padding="15">
                        <TextBlock x:Name="HelpText" TextWrapping="Wrap" Foreground="{DynamicResource TextPrimary}" FontSize="13" LineHeight="22"/>
                    </Border>

                    <!-- الزر يتبع AccentColor -->
                    <Button Content="{DynamicResource Close}" Margin="0,20,0,0" Width="100" Height="36" 
                            Background="{DynamicResource AccentColor}" Foreground="White" FontWeight="SemiBold"
                            Cursor="Hand" Click="Close_Click">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="8"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</Window>