<Window x:Class="CrystalFolders.Picker"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:hc="https://handyorg.github.io/handycontrol"
        TextOptions.TextRenderingMode="ClearType" TextOptions.TextFormattingMode="Display"
        SizeToContent="Height" UseLayoutRounding="True" ResizeMode="NoResize" Width="280"
        WindowStartupLocation="CenterOwner" Title="{DynamicResource ColorPickerTitle}" FontSize="12"
        Icon="/Resources/Icon.ico" ShowInTaskbar="False"
        AllowsTransparency="True" WindowStyle="None" Background="Transparent" MouseDown="Window_MouseDown">

    <Window.Resources>
        <!-- ✅ تم حذف تعريف الألوان الثابتة من هنا لتعمل ألوان Config.cs -->

        <Style x:Key="SectionCard" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource CardBackground}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderColor}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="15"/>
        </Style>

        <Style x:Key="ModernButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderColor}"/>
            <Setter Property="Height" Value="38"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource HoverColor}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource AccentColor}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Height" Value="38"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource AccentHoverColor}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="IconButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Width" Value="34"/>
            <Setter Property="Height" Value="34"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="Transparent" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#25FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Background="{DynamicResource AppBackground}" CornerRadius="15" BorderBrush="{DynamicResource BorderColor}" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="50"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- HEADER -->
            <Border Grid.Row="0" Background="{DynamicResource AccentColor}" CornerRadius="14,14,0,0">
                <Grid Margin="15,0">
                    <TextBlock Text="{DynamicResource ColorPickerTitle}" Foreground="White" FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    <Button Style="{StaticResource IconButton}" HorizontalAlignment="Right" Click="Cancel_Click">
                        <Viewbox Width="16" Height="16">
                            <Path Fill="White" Data="M19,6.41L17.59,5L12,10.59L6.41,5L5,6.41L10.59,12L5,17.59L6.41,19L12,13.41L17.59,19L19,17.59L13.41,12z"/>
                        </Viewbox>
                    </Button>
                </Grid>
            </Border>

            <StackPanel Grid.Row="1" Margin="15">
                <Border Style="{StaticResource SectionCard}" Padding="10" Margin="0,0,0,15">
                    <Grid Height="290">
                        <!-- الـ ColorPicker من HandyControl سيتبع الثيم تلقائياً الآن -->
                        <hc:ColorPicker x:Name="PickerControl" BorderThickness="0" SelectedColorChanged="PickerControl_SelectedColorChanged"/>
                    </Grid>
                </Border>
                <Border Style="{StaticResource SectionCard}" Padding="15" Margin="0">
                    <StackPanel>
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Button x:Name="Cancel" Content="{DynamicResource Cancel}" Grid.Column="0" Margin="0,0,5,0" Style="{StaticResource ModernButton}" Click="Cancel_Click"/>
                            <Button x:Name="DefaultBtn" Grid.Column="1" Margin="5,0,0,0" Style="{StaticResource ModernButton}" Click="Default_Click">
                                <StackPanel Orientation="Horizontal">
                                    <Viewbox Width="16" Height="16" Margin="0,0,8,0">
                                        <Path Fill="{DynamicResource AccentColor}" Data="M12,3C7.03,3,3,7.03,3,12s4.03,9,9,9c0.83,0,1.5-.67,1.5-1.5 0-.39-.15-.74-.39-1.01-.23-.26-.38-.61-.38-.99 0-.83.67-1.5,1.5-1.5H16c2.76,0,5-2.24,5-5 0-4.42-4.03-8-9-8zm-5.5,9c-.83,0-1.5-.67-1.5-1.5S5.67,9,6.5,9 8,9.67,8,10.5 7.33,12,6.5,12zm3-4C8.67,8,8,7.33,8,6.5S8.67,5,9.5,5s1.5.67,1.5,1.5S10.33,8,9.5,8zm5,0c-.83,0-1.5-.67-1.5-1.5S13.67,5,14.5,5s1.5.67,1.5,1.5S15.33,8,14.5,8zm3,4c-.83,0-1.5-.67-1.5-1.5S16.67,9,17.5,9s1.5.67,1.5,1.5-.67,1.5-1.5,1.5z"/>
                                    </Viewbox>
                                    <TextBlock Text="{DynamicResource Default}" VerticalAlignment="Center" Foreground="{DynamicResource TextPrimary}"/>
                                </StackPanel>
                            </Button>
                        </Grid>
                        <Button x:Name="Apply" Content="{DynamicResource Apply}" Style="{StaticResource PrimaryButton}" FontWeight="SemiBold" Click="Apply_Click"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Grid>
    </Border>
</Window>