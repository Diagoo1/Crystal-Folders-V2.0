<Window x:Class="CrystalFolders.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:hc="https://handyorg.github.io/handycontrol"
        mc:Ignorable="d" Title="{DynamicResource AppTitle}" FontFamily="Segoe UI" FontSize="12"
        Height="720" Width="850" Background="{x:Null}"
        AllowsTransparency="True" WindowStyle="None" MouseDown="Window_MouseDown"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize" Loaded="Window_Loaded"
        Icon="/Resources/Icon.ico">

    <Border Background="{DynamicResource AppBackground}" CornerRadius="20" BorderBrush="{DynamicResource BorderColor}" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="60"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Window Header -->
            <Border Grid.Row="0" Background="{DynamicResource AccentColor}" CornerRadius="19,19,0,0">
                <Grid Margin="20,0">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center">
                        <Border Width="32" Height="32" Background="White" CornerRadius="8" Padding="5">
                            <Image Source="/Resources/Icon.ico"/>
                        </Border>
                        <TextBlock Text="{DynamicResource AppTitle}" Foreground="White" FontSize="18" FontWeight="Bold" Margin="12,0,0,0" VerticalAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <Button Style="{StaticResource IconButton}" Click="ThemeToggle_Click" ToolTip="Toggle Theme">
                            <Grid>
                                <Viewbox x:Name="SunIcon" Width="20" Height="20" Visibility="Visible">
                                    <Path Fill="White" Data="M12,9c1.65,0,3,1.35,3,3s-1.35,3-3,3s-3-1.35-3-3S10.35,9,12,9 M12,7c-2.76,0-5,2.24-5,5s2.24,5,5,5s5-2.24,5-5 S14.76,7,12,7L12,7z M2,13l2,0c0.55,0,1-0.45,1-1s-0.45-1-1-1l-2,0c-0.55,0-1,0.45-1,1S1.45,13,2,13z M20,13l2,0c0.55,0,1-0.45,1-1 s-0.45-1-1-1l-2,0c-0.55,0-1,0.45-1,1S19.45,13,20,13z M11,2v2c0,0.55,0.45,1,1,1s1-0.45,1-1V2c0-0.55-0.45-1-1-1S11,1.45,11,2z M11,20v2c0,0.55,0.45,1,1,1s1-0.45,1-1v-2c0-0.55-0.45-1-1-1S11,19.45,11,20z M5.99,4.58c-0.39-0.39-1.03-0.39-1.41,0 c-0.39,0.39-0.39,1.03,0,1.41l1.06,1.06c0.39,0.39,1.03,0.39,1.41,0s0.39-1.03,0-1.41L5.99,4.58z M18.36,16.95 c-0.39-0.39-1.03-0.39-1.41,0c-0.39,0.39-0.39,1.03,0,1.41l1.06,1.06c0.39,0.39,1.03,0.39,1.41,0c0.39-0.39,0.39-1.03,0-1.41 L18.36,16.95z M19.42,5.99c0.39-0.39,0.39-1.03,0-1.41c-0.39-0.39-1.03-0.39-1.41,0l-1.06,1.06c-0.39,0.39-0.39,1.03,0,1.41 s1.03,0.39,1.41,0L19.42,5.99z M7.05,18.36c0.39-0.39,0.39-1.03,0-1.41c-0.39-0.39-1.03-0.39-1.41,0l-1.06,1.06 c-0.39,0.39-0.39,1.03,0,1.41s1.03,0.39,1.41,0L7.05,18.36z"/>
                                </Viewbox>
                                <Viewbox x:Name="MoonIcon" Width="18" Height="18" Visibility="Collapsed">
                                    <Path Fill="White" Data="M12,3c-4.97,0-9,4.03-9,9s4.03,9,9,9s9-4.03,9-9c0-0.46-0.04-0.92-0.1-1.36c-0.98,1.37-2.58,2.26-4.4,2.26 c-2.98,0-5.4-2.42-5.4-5.4c0-1.81,0.89-3.42,2.26-4.4C12.92,3.04,12.46,3,12,3z"/>
                                </Viewbox>
                            </Grid>
                        </Button>
                        <Button x:Name="ClearList" Style="{StaticResource IconButton}" Click="Refresh_Click" ToolTip="Refresh App">
                            <Viewbox Width="18" Height="18">
                                <Path Fill="White" Data="M17.65,6.35C16.2,4.9,14.21,4,12,4c-4.42,0-7.99,3.58-7.99,8s3.57,8,7.99,8c3.73,0,6.84-2.55,7.73-6h-2.08 c-0.82,2.33-3.04,4-5.65,4c-3.31,0-6-2.69-6-6s2.69-6,6-6c1.66,0,3.14,0.69,4.22,1.78L13,11h7V4z"/>
                            </Viewbox>
                        </Button>
                        <Button x:Name="Info" Style="{StaticResource IconButton}" Click="Info_Click" ToolTip="About">
                            <Viewbox Width="18" Height="18">
                                <Path Fill="White" Data="M12,2C6.48,2,2,6.48,2,12s4.48,10,10,10s10-4.48,10-10S17.52,2,12,2z M13,17h-2v-6h2V17z M13,9h-2V7h2V9z"/>
                            </Viewbox>
                        </Button>
                        <Button Style="{StaticResource IconButton}" Click="Exit_Click" ToolTip="Exit">
                            <Viewbox Width="18" Height="18">
                                <Path Fill="White" Data="M19,6.41L17.59,5L12,10.59L6.41,5L5,6.41L10.59,12L5,17.59L6.41,19L12,13.41L17.59,19L19,17.59L13.41,12z"/>
                            </Viewbox>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Main Content Area -->
            <Grid Grid.Row="1" Margin="25">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="1.1*"/>
                </Grid.ColumnDefinitions>

                <!-- Left Panel -->
                <Grid Grid.Column="0" Margin="0,0,15,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" Style="{StaticResource SectionCard}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,15">
                                <Viewbox Width="20" Height="20">
                                    <Path Fill="{DynamicResource AccentColor}" Data="M20,18c1.1,0,2-0.9,2-2V6c0-1.1-0.9-2-2-2H12l-2-2H4C2.9,2,2.01,2.9,2.01,4L2,16c0,1.1,0.9,2,2,2H20z"/>
                                </Viewbox>
                                <TextBlock Text="{DynamicResource ManageFolders}" Style="{StaticResource SectionHeaderText}"/>
                            </StackPanel>
                            <Border Grid.Row="1" Background="{DynamicResource AppBackground}" BorderBrush="{DynamicResource BorderColor}" BorderThickness="1" CornerRadius="12">
                                <ListBox x:Name="DropList" SelectionMode="Extended" Background="Transparent" BorderThickness="0" Padding="8" AllowDrop="True" Drop="DropList_Drop" DragEnter="DropList_DragEnter" Foreground="{DynamicResource TextPrimary}" SelectionChanged="DropList_SelectionChanged"/>
                            </Border>
                            <Grid Grid.Row="2" Margin="0,15,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="1.5*"/>
                                </Grid.ColumnDefinitions>
                                <Button x:Name="Remove" Content="{DynamicResource Remove}" Grid.Column="0" Height="40" Margin="0,0,10,0" Style="{StaticResource ModernButton}" BorderBrush="#FFC1C1" Foreground="#D32F2F" Click="Remove_Click"/>
                                <Button x:Name="Remove_All" Content="{DynamicResource RemoveAll}" Grid.Column="1" Height="40" Margin="0,0,10,0" Style="{StaticResource ModernButton}" BorderBrush="{DynamicResource BorderColor}" Click="RemoveAll_Click" Foreground="{DynamicResource TextPrimary}"/>
                                <Button x:Name="BrowseBtn" Content="{DynamicResource Browse}" Grid.Column="2" Height="40" Style="{StaticResource PrimaryButton}" FontWeight="Bold" Click="BrowseBtn_Click"/>
                            </Grid>
                        </Grid>
                    </Border>
                    <Border Grid.Row="1" Style="{StaticResource SectionCard}" Margin="0">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                                <Viewbox Width="20" Height="20">
                                    <Path Fill="{DynamicResource AccentColor}" Data="M11,7h2v2h-2V7z M11,11h2v6h-2V11z M12,2C6.48,2,2,6.48,2,12s4.48,10,10,10s10-4.48,10-10S17.52,2,12,2z"/>
                                </Viewbox>
                                <TextBlock Text="{DynamicResource Summary}" Style="{StaticResource SectionHeaderText}"/>
                            </StackPanel>
                            <UniformGrid Columns="2">
                                <Border Background="#150984E3" CornerRadius="10" Padding="15" Margin="0,0,10,0">
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                        <TextBlock Text="{DynamicResource Folders}" VerticalAlignment="Center" FontWeight="SemiBold" Foreground="{DynamicResource AccentColor}" Margin="0,0,10,0"/>
                                        <hc:Badge x:Name="Dot" Value="0" Style="{StaticResource BadgePrimary}" VerticalAlignment="Center" BadgeMargin="0"/>
                                    </StackPanel>
                                </Border>
                                <Border Background="#15F39C12" CornerRadius="10" Padding="15">
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                        <TextBlock Text="{DynamicResource SubFolders}" VerticalAlignment="Center" FontWeight="SemiBold" Foreground="#D35400" Margin="0,0,10,0"/>
                                        <hc:Badge x:Name="Dotsub" Value="0" Style="{StaticResource BadgeWarning}" VerticalAlignment="Center" BadgeMargin="0"/>
                                    </StackPanel>
                                </Border>
                            </UniformGrid>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- Right Panel -->
                <Grid Grid.Column="1">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Icon Preview -->
                    <Border Grid.Row="0" Style="{StaticResource SectionCard}">
                        <StackPanel>
                            <Grid Margin="0,0,0,15">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center">
                                    <Viewbox Width="20" Height="20">
                                        <Path Fill="{DynamicResource AccentColor}" Data="M21,19V5c0-1.1-0.9-2-2-2H5C3.9,3,3,3.9,3,5v14c0,1.1,0.9,2,2,2h14C20.1,21,21,20.1,21,19z M8.5,13.5l2.5,3.01L14.5,12l4.5,6H5 L8.5,13.5z"/>
                                    </Viewbox>
                                    <TextBlock Text="{DynamicResource IconPreview}" Style="{StaticResource SectionHeaderText}"/>
                                </StackPanel>

                                <!-- ✅ الزر مع حواف ديناميكية تتغير حسب اللون المختار -->
                                <Button Style="{StaticResource ModernButton}" 
                                        Click="OpenConverter_Click" 
                                        HorizontalAlignment="Right" 
                                        VerticalAlignment="Center" 
                                        Width="32" Height="32" Padding="0"
                                        BorderBrush="{DynamicResource AccentColor}"
                                        BorderThickness="1.5"
                                        ToolTip="{DynamicResource IconConverter}">
                                    <Viewbox Width="18" Height="18">
                                        <Path Fill="{DynamicResource AccentColor}" Data="M12,6V9L16,5L12,1V4C7,4 3,8 3,13C3,14.46 3.35,15.82 3.95,17L5.41,15.54C5.15,14.77 5,13.9 5,13C5,9.13 8.13,6 12,6M18.05,9L16.59,10.46C16.85,11.23 17,12.1 17,13C17,16.87 13.87,20 10,20V17L6,21L10,25V22C15,22 19,18 19,13C19,11.54 18.65,10.18 18.05,9Z"/>
                                    </Viewbox>
                                </Button>
                            </Grid>

                            <Border x:Name="IconPreviewArea" Height="220" Background="{DynamicResource AppBackground}" CornerRadius="12" BorderThickness="1" BorderBrush="{DynamicResource BorderColor}" MouseLeftButtonDown="IconPreviewArea_MouseLeftButtonDown" Cursor="Hand">
                                <Grid>
                                    <hc:DashedBorder x:Name="Icon_border" BorderBrush="{DynamicResource BorderColor}" BorderThickness="1.5" CornerRadius="10" Margin="10"/>
                                    <Image x:Name="Iconpic" Width="128" Height="128" Stretch="Uniform" RenderOptions.BitmapScalingMode="HighQuality">
                                        <Image.Effect>
                                            <DropShadowEffect BlurRadius="15" ShadowDepth="4" Opacity="0.15"/>
                                        </Image.Effect>
                                    </Image>
                                    <Viewbox x:Name="Icon_cross" Width="40" Height="40" Opacity="0.2">
                                        <Path Fill="{DynamicResource TextPrimary}" Data="M19,13H13V19H11V13H5V11H11V5H13V11H19V13Z"/>
                                    </Viewbox>
                                    <Viewbox x:Name="Icon_restore" Width="40" Height="40" Opacity="0.3" Visibility="Collapsed">
                                        <Path Fill="{DynamicResource AccentColor}" Data="M13,3c-4.97,0-9,4.03-9,9H1l3.89,3.89l0.07,0.14L9,12H6c0-3.87,3.13-7,7-7s7,3.13,7,7s-3.13,7-7,7c-1.93,0-3.68-0.79-4.94-2.06l-1.42,1.42C8.27,19.99,10.51,21,13,21c4.97,0,9-4.03,9-9S17.97,3,13,3z"/>
                                    </Viewbox>
                                </Grid>
                            </Border>
                            <UniformGrid Columns="2" Margin="0,15,0,0">
                                <Button x:Name="ChooseBtn" Content="{DynamicResource ChooseIcon}" Height="38" Margin="0,0,5,0" Style="{StaticResource ModernButton}" BorderBrush="{DynamicResource AccentColor}" Click="ChooseBtn_Click" Foreground="{DynamicResource TextPrimary}"/>
                                <Button x:Name="RestoreBtn" Content="{DynamicResource Restore}" Height="38" Margin="5,0,0,0" Style="{StaticResource ModernButton}" BorderBrush="{DynamicResource BorderColor}" Click="RestoreBtn_Click" Foreground="{DynamicResource TextPrimary}"/>
                            </UniformGrid>
                        </StackPanel>
                    </Border>

                    <!-- Settings -->
                    <Border Grid.Row="1" Style="{StaticResource SectionCard}">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                                <Viewbox Width="20" Height="20">
                                    <Path Fill="{DynamicResource AccentColor}" Data="M19.14,12.94c0.04-0.3,0.06-0.61,0.06-0.94c0-0.32-0.02-0.64-0.07-0.94l2.03-1.58c0.18-0.14,0.23-0.41,0.12-0.61 l-1.92-3.32c-0.12-0.22-0.37-0.29-0.59-0.22l-2.39,0.96c-0.5-0.38-1.03-0.7-1.62-0.94L14.4,2.81c-0.04-0.24-0.24-0.41-0.48-0.41 h-3.84c-0.24,0-0.43,0.17-0.47,0.41l-0.36,2.54c-0.59-0.24-1.13,0.57-1.62,0.94L5.24,5.33c-0.22-0.07-0.47,0-0.59,0.22L2.74,8.87 C2.62,9.08,2.66,9.34,2.84,9.48l2.03,1.58C4.82,11.36,4.8,11.68,4.8,12c0,0.32,0.02,0.64,0.07,0.94l-2.03,1.58 c-0.18,0.14-0.23,0.41-0.12,0.61l1.92,3.32c0.12,0.22,0.37,0.29,0.59,0.22l2.39-0.96c0.5,0.38,1.03,0.7,1.62,0.94l0.36,2.54 c0.05,0.24,0.24,0.41,0.48,0.41h3.84c0.24,0,0.44-0.17,0.47-0.41l0.36-2.54c0.59-0.24,1.13-0.57,1.62-0.94l2.39,0.96 c0.22,0.07,0.47,0,0.59-0.22l1.92-3.32c0.12-0.22,0.07-0.47-0.12-0.61L19.14,12.94z M12,15.6c-1.98,0-3.6-1.62-3.6-3.6 s1.62-3.6,3.6-3.6s3.6,1.62,3.6,3.6S13.98,15.6,12,15.6z"/>
                                </Viewbox>
                                <TextBlock Text="{DynamicResource Settings}" Style="{StaticResource SectionHeaderText}"/>
                            </StackPanel>
                            <Grid Margin="0,5">
                                <TextBlock Text="{DynamicResource IncludeSubfolders}" VerticalAlignment="Center" Foreground="{DynamicResource TextPrimary}" FontSize="13"/>
                                <ToggleButton x:Name="SlideSub" HorizontalAlignment="Right" Style="{StaticResource ToggleButtonSwitch}" Checked="SlideSub_Checked" Unchecked="SlideSub_Unchecked"/>
                            </Grid>
                            <Grid Margin="0,10,0,0">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{DynamicResource PortableMode}" VerticalAlignment="Center" Foreground="{DynamicResource TextPrimary}" FontSize="13"/>
                                    <Button x:Name="Help" Style="{StaticResource IconButton}" Click="Help_Click" Width="24" Height="24" Margin="8,0,0,0">
                                        <Viewbox Width="16" Height="16">
                                            <Path Fill="{DynamicResource AccentColor}" Data="M11,18h2v-2h-2V18z M12,2C6.48,2,2,6.48,2,12s4.48,10,10,10s10-4.48,10-10S17.52,2,12,2z M12,20c-4.41,0-8-3.59-8-8 s3.59-8,8-8s8,3.59,8,8S16.41,20,12,20z M12,6c-2.21,0-4,1.79-4,4h2c0-1.1,0.9-2,2-2s2,0.9,2,2c0,2-3,1.75-3,5h2 c0-2.25,3-2.5,3-5C16,7.79,14.21,6,12,6z"/>
                                        </Viewbox>
                                    </Button>
                                </StackPanel>
                                <ToggleButton x:Name="SlidePortable" HorizontalAlignment="Right" Style="{StaticResource ToggleButtonSwitch}" Click="SlidePortable_Click"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- Customize Button -->
                    <Button x:Name="Customize" Grid.Row="3" Content="{DynamicResource ApplyCustomization}" Height="60" Margin="0,0,0,20" Style="{StaticResource PrimaryButton}" FontSize="16" FontWeight="Bold" Click="Customize_Click">
                        <Button.Effect>
                            <DropShadowEffect BlurRadius="15" ShadowDepth="4" Opacity="0.3" Color="{Binding Color, Source={StaticResource AccentColor}}"/>
                        </Button.Effect>
                    </Button>
                </Grid>
            </Grid>
        </Grid>
    </Border>
</Window>