<Window x:Class="CrystalFolders.IconConverterWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:hc="https://handyorg.github.io/handycontrol"
        Title="{DynamicResource IconConverter}" Height="480" Width="400"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        WindowStartupLocation="CenterOwner" MouseDown="Window_MouseDown">

    <Window.Resources>
        <!-- استايل موحد للأزرار الثانوية يتناسب مع الدارك مود -->
        <Style x:Key="ConverterModernButton" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource CardBackground}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderColor}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource HoverColor}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Background="{DynamicResource AppBackground}" CornerRadius="20" BorderBrush="{DynamicResource BorderColor}" BorderThickness="1" Margin="10">
        <Border.Effect>
            <DropShadowEffect BlurRadius="15" ShadowDepth="0" Opacity="0.2" Color="Black"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="50"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Background="{DynamicResource AccentColor}" CornerRadius="19,19,0,0">
                <Grid Margin="15,0">
                    <TextBlock Text="{DynamicResource IconConverter}" Foreground="White" FontSize="16" FontWeight="Bold" VerticalAlignment="Center"/>
                    <Button HorizontalAlignment="Right" Style="{StaticResource IconButton}" Click="Close_Click">
                        <Viewbox Width="14" Height="14">
                            <Path Fill="White" Data="M19,6.41L17.59,5L12,10.59L6.41,5L5,6.41L10.59,12L5,17.59L6.41,19L12,13.41L17.59,19L19,17.59L13.41,12z"/>
                        </Viewbox>
                    </Button>
                </Grid>
            </Border>

            <!-- Content -->
            <StackPanel Grid.Row="1" Margin="20">
                <!-- Preview Area -->
                <!-- ✅ تم تصحيح الـ Margin هنا من 0,0,0= إلى 0,0,0,5 -->
                <Border Style="{StaticResource SectionCard}" Height="180" Margin="0,0,0,5" Padding="0" Background="{DynamicResource CardBackground}">
                    <Grid>
                        <Image x:Name="ImgPreview" Stretch="Uniform" Margin="15" RenderOptions.BitmapScalingMode="HighQuality"/>
                        <StackPanel x:Name="PlaceholderText" VerticalAlignment="Center" HorizontalAlignment="Center" Opacity="0.4">
                            <Viewbox Width="40" Height="40" Margin="0,0,0,10">
                                <Path Fill="{DynamicResource TextPrimary}" Data="M21,19V5c0-1.1-0.9-2-2-2H5C3.9,3,3,3.9,3,5v14c0,1.1,0.9,2,2,2h14C20.1,21,21,20.1,21,19z M8.5,13.5l2.5,3.01L14.5,12l4.5,6H5 L8.5,13.5z"/>
                            </Viewbox>
                            <TextBlock Text="{DynamicResource SelectImageToPreview}" Foreground="{DynamicResource TextPrimary}" FontWeight="Medium"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- زر اختيار الصورة -->
                <Button Content="{DynamicResource BrowseImage}" Style="{StaticResource ConverterModernButton}" Height="42" Margin="0,15,0,12" Click="Browse_Click"/>

                <!-- سطر حفظ المسار -->
                <Grid Margin="0,0,0,15">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBox x:Name="SavePathTxt" 
                             hc:InfoElement.Placeholder="{DynamicResource SaveLocation}" 
                             IsReadOnly="True" 
                             Style="{StaticResource TextBoxExtend}" 
                             Height="42" 
                             Background="{DynamicResource CardBackground}" 
                             Foreground="{DynamicResource TextPrimary}" 
                             BorderBrush="{DynamicResource BorderColor}"/>

                    <Button Grid.Column="1" Content="..." Width="45" Margin="8,0,0,0" Style="{StaticResource ConverterModernButton}" Click="SaveLocation_Click"/>
                </Grid>

                <!-- زر التحويل الرئيسي -->
                <Button x:Name="ConvertBtn" Content="{DynamicResource ConvertAndSave}" Style="{StaticResource PrimaryButton}" Height="55" FontSize="15" FontWeight="Bold" Click="Convert_Click">
                    <Button.Effect>
                        <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.2" Color="{Binding Color, Source={StaticResource AccentColor}}"/>
                    </Button.Effect>
                </Button>
            </StackPanel>
        </Grid>
    </Border>
</Window>