<Window x:Class="CrystalFolders.About"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:hc="https://handyorg.github.io/handycontrol"
        Title="{DynamicResource About}" Height="500" Width="820" Background="{x:Null}" 
        AllowsTransparency="True" WindowStyle="None" MouseDown="Window_MouseDown" 
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize" Loaded="Window_Loaded" Closing="Window_Closing">

    <Window.Resources>
        <Style x:Key="IndicatorStyle" TargetType="Label">
            <Setter Property="Width" Value="4"/>
            <Setter Property="Height" Value="24"/>
            <Setter Property="Background" Value="{DynamicResource AccentColor}"/>
            <Setter Property="HorizontalAlignment" Value="Left"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Label">
                        <Border Background="{TemplateBinding Background}" CornerRadius="2"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ThemeButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="{DynamicResource AccentColor}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="8" Padding="10,5">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#150984E3"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Background="{DynamicResource AppBackground}" CornerRadius="20" BorderBrush="{DynamicResource BorderColor}" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="65"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Border Background="{DynamicResource AccentColor}" CornerRadius="19,19,0,0">
                <Grid Margin="20,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Border Width="34" Height="34" Background="White" CornerRadius="8" Padding="5">
                            <Image Source="/Resources/Icon.ico"/>
                        </Border>
                        <TextBlock x:Name="HeaderTitle" Text="{DynamicResource CrystalFoldersTitle}" Foreground="White" FontSize="17" FontWeight="Bold" Margin="12,0,0,0" VerticalAlignment="Center"/>
                    </StackPanel>
                    <Button HorizontalAlignment="Right" Click="Back_Click" Background="Transparent" BorderThickness="0" Cursor="Hand">
                        <Viewbox Width="16" Height="16">
                            <Path Fill="White" Data="M19,6.41L17.59,5L12,10.59L6.41,5L5,6.41L10.59,12L5,17.59L6.41,19L12,13.41L17.59,19L19,17.59L13.41,12z"/>
                        </Viewbox>
                    </Button>
                </Grid>
            </Border>

            <Grid Grid.Row="1" Margin="25">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="230"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Grid Grid.Column="0" Margin="0,0,10,0">
                    <Image Source="/Resources/Icon.ico" Width="85" Height="85" Margin="0,5,0,30" HorizontalAlignment="Center" VerticalAlignment="Top"/>
                    <Border Margin="0,120,0,0" Style="{StaticResource SectionCard}" VerticalAlignment="Top" Padding="10">
                        <StackPanel>
                            <Grid Cursor="Hand" MouseDown="Btn_1_MouseDown" Margin="0,0,0,5">
                                <Border Background="#120984E3" CornerRadius="10" Visibility="{Binding Visibility, ElementName=Arrw_1}"/>
                                <StackPanel Orientation="Horizontal" Margin="10,8">
                                    <Label x:Name="Arrw_1" Style="{StaticResource IndicatorStyle}"/>
                                    <TextBlock x:Name="Btn_1" Text="{DynamicResource CrystalFoldersTitle}" FontWeight="Bold" FontSize="13" Foreground="{DynamicResource TextPrimary}" Margin="12,0,0,0" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Grid>
                            <Grid Cursor="Hand" MouseDown="Btn_2_MouseDown">
                                <Border Background="#120984E3" CornerRadius="10" Visibility="{Binding Visibility, ElementName=Arrw_2}"/>
                                <StackPanel Orientation="Horizontal" Margin="10,8">
                                    <Label x:Name="Arrw_2" Style="{StaticResource IndicatorStyle}" Visibility="Hidden"/>
                                    <TextBlock x:Name="Btn_2" Text="{DynamicResource CrystalIconsTitle}" FontWeight="Bold" FontSize="13" Foreground="{DynamicResource TextPrimary}" Margin="12,0,0,0" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>
                </Grid>

                <Grid Grid.Column="1" Margin="10,0,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Border Style="{StaticResource SectionCard}" Padding="20">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Text="{DynamicResource Info}" Foreground="{DynamicResource AccentColor}" FontWeight="Bold" FontSize="14" Margin="0,0,0,15"/>

                            <hc:ScrollViewer Grid.Row="1">
                                <hc:TextBox x:Name="License" IsReadOnly="True" TextWrapping="Wrap" BorderThickness="0" Background="Transparent" FontSize="12.5" Foreground="{DynamicResource TextPrimary}" Opacity="0.8"/>
                            </hc:ScrollViewer>

                            <Border Grid.Row="2" Background="#080984E3" CornerRadius="12" Padding="15,10" Margin="0,15,0,0">
                                <Button x:Name="Link" Click="Link_Click" Background="Transparent" BorderThickness="0" Cursor="Hand" HorizontalAlignment="Left">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="🔗" Margin="0,0,10,0" VerticalAlignment="Center" Foreground="{DynamicResource AccentColor}"/>
                                        <TextBlock x:Name="Description" Text="Description..." FontWeight="Bold" Foreground="{DynamicResource AccentColor}" VerticalAlignment="Center" TextWrapping="Wrap"/>
                                    </StackPanel>
                                </Button>
                            </Border>
                        </Grid>
                    </Border>

                    <Grid Grid.Row="1" Margin="0,20,0,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{DynamicResource Language}" VerticalAlignment="Center" Foreground="#FF8E8E8E" Margin="0,0,10,0" FontSize="11"/>
                            <hc:ComboBox x:Name="LangBox" Width="140" hc:BorderElement.CornerRadius="8" Margin="0,0,15,0" Height="32" SelectedIndex="0">
                                <ComboBoxItem Content="{DynamicResource English}"/>
                                <ComboBoxItem Content="{DynamicResource Arabic}"/>
                            </hc:ComboBox>
                            <Button x:Name="ChangeTheme" Click="ChangeTheme_Click" Width="160" Height="32" Style="{StaticResource ThemeButtonStyle}">
                                <StackPanel Orientation="Horizontal">
                                    <Viewbox Width="18" Height="18" Margin="0,0,10,0">
                                        <Path Fill="{DynamicResource AccentColor}" Data="M12,3c-4.97,0-9,4.03-9,9s4.03,9,9,9c0.83,0,1.5-0.67,1.5-1.5c0-0.39-0.15-0.75-0.39-1.01c-0.23-0.26-0.38-0.61-0.38-0.99 c0-0.83,0.67-1.5,1.5-1.5H16c2.21,0,4-1.79,4-4C20,7.14,16.42,3,12,3z M7,12c-0.55,0-1-0.45-1-1s0.45-1,1-1s1,0.45,1,1S7.55,12,7,12z M9,8c-0.55,0-1-0.45-1-1s0.45-1,1-1s1,0.45,1,1S9.55,8,9,8z M12,7c-0.55,0-1-0.45-1-1s0.45-1,1-1s1,0.45,1,1S12.55,7,12,7z M15,8 c-0.55,0-1-0.45-1-1s0.45-1,1-1s1,0.45,1,1S15.55,8,15,8z"/>
                                    </Viewbox>
                                    <TextBlock Text="{DynamicResource Theme}" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource TextPrimary}" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Grid>
                </Grid>
            </Grid>
        </Grid>
    </Border>
</Window>